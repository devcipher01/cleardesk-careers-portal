# Copy to Vercel Environment Variables (Production + Preview)
# For local dev: set PUBLIC_BASE_URL=http://localhost:5000 and LOCAL_DEV_MODE=true

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
LOCAL_DEV_MODE=false

ADMIN_PASSWORD=

PUBLIC_BASE_URL=http://localhost:5000
ADMIN_NOTIFY_EMAIL=you@example.com

PIPELINE_EMAIL_DELAY_MIN_HOURS=18
PIPELINE_EMAIL_DELAY_MAX_HOURS=24

CRON_SECRET=

MAIL_FROM="Worknesta <talent@worknesta.com>"
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-login@smtp-brevo.com
SMTP_PASS=
SMTP_SECURE=false

# Local-only (not needed on Vercel when LOCAL_DEV_MODE=false):
# LOCAL_PIPELINE_EMAIL_DELAY_MS=0
